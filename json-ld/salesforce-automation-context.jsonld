        },
        "Description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "ProcessType": {
          "@id": "sfauto:processType",
          "@type": "xsd:string"
        },
        "TriggerType": {
          "@id": "sfauto:triggerType",
