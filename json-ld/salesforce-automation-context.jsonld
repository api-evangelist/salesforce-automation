        },
        "LastModifiedDate": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        },
        "CreatedById": {
          "@id": "sfauto:createdBy",
          "@type": "@id"
        },
        "LastModifiedById": {
          "@id": "sfauto:lastModifiedBy",
          "@type": "@id"
        }
      }
    },

    "FlowDefinition": {
